{
    "name": "cached_node-modules",
    "version": "7.0.0",
    "private": true,
    "description": "A GitHub Action to cache node_modules",
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "scripts": {
        "lint:check": "eslint .",
        "lint:check-ci": "eslint --exit-on-fatal-error -f ./node_modules/@annangela/eslint-formatter-gha/dist/index.js --max-warnings 0 .",
        "lint:write": "eslint --fix .",
        "package": "bash scripts/package.sh",
        "test": "vitest run --coverage",
        "ci": "trap 'code=$?; node scripts/ci/after.js; exit $code' EXIT && rm -rdf node_modules && node scripts/ci/before.js && npm ci"
    },
    "engines": {
        "node": "^24.11"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AnnAngela/cached_node-modules.git"
    },
    "keywords": [
        "actions",
        "node",
        "node_modules"
    ],
    "author": "AnnAngela",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/AnnAngela/cached_node-modules/issues"
    },
    "homepage": "https://github.com/AnnAngela/cached_node-modules#readme",
    "devDependencies": {
        "@annangela/eslint-config": "^15.0.0",
        "@annangela/eslint-formatter-gha": "^6.1.1",
        "@types/node": "^25.9.3",
        "@types/semver": "^7.7.1",
        "@types/shell-quote": "^1.7.5",
        "@vitest/coverage-v8": "^4.1.9",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "memfs": "^4.57.7",
        "simple-git": "^3.36.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@actions/cache": "^6.1.0",
        "@actions/core": "^3.0.1",
        "@actions/github": "^9.1.1",
        "@octokit/auth-action": "^6.0.2",
        "@octokit/plugin-retry": "^8.1.0",
        "@octokit/rest": "^22.0.1",
        "semver": "^7.8.3",
        "shell-quote": "^1.8.4",
        "yaml": "^2.9.0"
    }
}
